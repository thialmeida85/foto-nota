# Obrigatoria no Render e no backend.
# Use a connection string do Neon PostgreSQL.
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require&channel_binding=require

# O Render injeta PORT automaticamente. Localmente pode usar 3000.
PORT=3000

# No Render use production.
NODE_ENV=production

# Login do app Foto Notas. Cadastre como Secret no Render.
APP_AUTH_EMAIL=seu_email_de_acesso
APP_AUTH_PASSWORD=sua_senha_de_acesso
APP_AUTH_SECRET=uma_chave_grande_aleatoria_para_assinar_sessoes

# Site de envio das notas.
NOTABE_URL=https://asin.notabe.com/notes/new

# Credenciais do NotaBe para primeiro login automatico.
# Cadastre como Secret no Render. Nao coloque valores reais no Git.
NOTABE_USERNAME=seu_usuario_ou_email_notabe
NOTABE_PASSWORD=sua_senha_notabe

# No Render precisa ser 0 para instalar/usar o Chromium junto do app.
PLAYWRIGHT_BROWSERS_PATH=0

# Opcional. Em producao o backend sempre usa headless true.
# Para login manual local, use false.
PLAYWRIGHT_HEADLESS=true

# Opcional, mas necessario para usar o botao "Corrigir com IA".
# Cadastre como Secret no Render, nao coloque a chave real no Git.
GROQ_API_KEY=gsk_sua_chave_aqui
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
